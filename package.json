{
  "name": "scriptcut",
  "version": "0.1.0",
  "private": true,
  "description": "ScriptCut — Open-source AI-powered text-based video editor",
  "keywords": [
    "video-editor",
    "text-based-video-editing",
    "descript-alternative",
    "transcript-editor",
    "youtube-shorts",
    "tiktok",
    "reels",
    "creator-tools",
    "captions",
    "ffmpeg",
    "local-first",
    "electron"
  ],
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "electron .",
    "dev:backend": "node electron/run-backend.js --reload --port 8642",
    "setup": "node scripts/setup.js",
    "setup:backend": "node scripts/setup.js --backend-only",
    "doctor": "node scripts/doctor.js",
    "build": "cd frontend && npm run build && electron-builder",
    "build:frontend": "cd frontend && npm run build",
    "dist": "npm run build",
    "dist:mac": "npm run build:frontend && electron-builder --mac dmg",
    "dist:dir": "npm run build:frontend && electron-builder --dir",
    "qa:desktop": "node scripts/desktop-qa.js",
    "qa:desktop:package": "node scripts/desktop-qa.js --package",
    "lint": "cd frontend && npm run lint",
    "smoke:backend": "cd backend && (../.venv311/bin/python scripts/smoke_backend.py || ../.venv/bin/python scripts/smoke_backend.py || python scripts/smoke_backend.py)"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "python-shell": "^5.0.0"
  },
  "build": {
    "appId": "com.fernandoabishai.scriptcut",
    "productName": "ScriptCut",
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "shared/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
